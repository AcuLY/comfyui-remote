{
  "name": "comfyui-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:generate:sqlite": "DB_PROVIDER=sqlite prisma generate",
    "prisma:generate:all": "prisma generate && DB_PROVIDER=sqlite prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:db:push": "prisma db push",
    "prisma:seed": "node --experimental-strip-types prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "db:seed": "npx tsx src/scripts/seed.mts",
    "db:bootstrap": "prisma migrate dev && npx tsx src/scripts/seed.mts",
    "db:bootstrap:sqlite": "DB_PROVIDER=sqlite prisma generate && DB_PROVIDER=sqlite DATABASE_URL=file:./data/comfyui.db prisma migrate dev && DB_PROVIDER=sqlite DATABASE_URL=file:./data/comfyui.db npx tsx src/scripts/seed.mts"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.0.0",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
