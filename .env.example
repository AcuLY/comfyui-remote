# ===========================================================================
# ComfyUI Remote — 环境变量
# 复制此文件为 .env 并按需修改
# ===========================================================================

# ---------------------------------------------------------------------------
# 数据库（必填）
# ---------------------------------------------------------------------------
# 数据库 Provider："postgresql"（默认）或 "sqlite"
# 使用 SQLite 时无需 Docker，数据保存在本地文件中
DB_PROVIDER="postgresql"

# PostgreSQL 连接串（DB_PROVIDER=postgresql 时使用）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/comfyui_manager"

# SQLite 文件路径（DB_PROVIDER=sqlite 时使用）
# DATABASE_URL="file:./data/comfyui.db"

# ---------------------------------------------------------------------------
# ComfyUI 连接
# ---------------------------------------------------------------------------
# ComfyUI API 地址
COMFY_API_URL="http://127.0.0.1:8188"
# HTTP 请求超时（毫秒）
COMFY_REQUEST_TIMEOUT_MS="10000"
# 轮询 /history 的间隔（毫秒）
COMFY_HISTORY_POLL_INTERVAL_MS="2000"
# 轮询 /history 的最大次数
COMFY_HISTORY_MAX_ATTEMPTS="15"

# ---------------------------------------------------------------------------
# 文件路径
# ---------------------------------------------------------------------------
# LoRA 文件存放根目录（上传 LoRA 时写入此目录，必填才能上传）
# macOS 示例: /Users/yourname/ComfyUI/models/loras
# Windows 示例: D:/ComfyUI/models/loras
MODEL_BASE_DIR=""

# 生成图片的 serving 根目录（前端展示用，可选；默认为 {项目目录}/data/images）
# OUTPUT_BASE_PATH=""

# ---------------------------------------------------------------------------
# 应用
# ---------------------------------------------------------------------------
# 应用 URL（用于 Server Action 内部调用，默认 http://localhost:3000）
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# ComfyUI 进程管理（可选，不配 COMFY_LAUNCH_CMD 则不启用进程管理）
# ---------------------------------------------------------------------------
# 启动命令（shell 执行），例:
#   "conda run -n comfyui python main.py --listen"
#   "/path/to/venv/bin/python main.py --listen 0.0.0.0"
COMFY_LAUNCH_CMD=""
# ComfyUI 工作目录（执行上述命令时的 cwd）
COMFY_LAUNCH_CWD=""
# 应用启动时自动拉起 ComfyUI（true/false）
COMFY_AUTO_START="false"
# 健康检查失败时自动重启（true/false）
COMFY_AUTO_RESTART="true"
# 健康检查间隔（毫秒，默认 10000）
COMFY_HEALTH_INTERVAL_MS="10000"
# 滑动窗口内最大重启次数（默认 3）
COMFY_MAX_RESTARTS="3"
# 重启计数窗口（毫秒，默认 300000 = 5 分钟）
COMFY_RESTART_WINDOW_MS="300000"
