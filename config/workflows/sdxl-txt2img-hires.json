{
  "id": "sdxl-txt2img-hires",
  "name": "SDXL Text-to-Image + HiRes Fix",
  "description": "SDXL txt2img with a second KSampler pass for higher resolution detail. Produces sharper images at the cost of longer generation time.",
  "version": "1.0.0",
  "builtIn": false,
  "variables": {
    "checkpoint": {
      "type": "string",
      "default": "sd_xl_base_1.0.safetensors",
      "description": "SDXL checkpoint file name",
      "nodeId": "1",
      "field": "inputs.ckpt_name"
    },
    "positivePrompt": {
      "type": "string",
      "default": "",
      "description": "Positive prompt text",
      "nodeId": "3",
      "field": "inputs.text"
    },
    "negativePrompt": {
      "type": "string",
      "default": "bad anatomy, extra limbs, blurry, low quality, watermark",
      "description": "Negative prompt text",
      "nodeId": "4",
      "field": "inputs.text"
    },
    "width": {
      "type": "number",
      "default": 896,
      "description": "Image width in pixels",
      "nodeId": "5",
      "field": "inputs.width"
    },
    "height": {
      "type": "number",
      "default": 1152,
      "description": "Image height in pixels",
      "nodeId": "5",
      "field": "inputs.height"
    },
    "batchSize": {
      "type": "number",
      "default": 1,
      "description": "Number of images to generate per run",
      "nodeId": "5",
      "field": "inputs.batch_size"
    },
    "seed": {
      "type": "number",
      "default": -1,
      "description": "Random seed (-1 for random)",
      "nodeId": "6",
      "field": "inputs.seed"
    },
    "steps": {
      "type": "number",
      "default": 20,
      "description": "First pass sampling steps",
      "nodeId": "6",
      "field": "inputs.steps"
    },
    "cfg": {
      "type": "number",
      "default": 7.0,
      "description": "Classifier-free guidance scale",
      "nodeId": "6",
      "field": "inputs.cfg"
    },
    "hiresSteps": {
      "type": "number",
      "default": 10,
      "description": "Second pass (hires fix) sampling steps",
      "nodeId": "9",
      "field": "inputs.steps"
    },
    "hiresDenoise": {
      "type": "number",
      "default": 0.45,
      "description": "Second pass denoise strength",
      "nodeId": "9",
      "field": "inputs.denoise"
    },
    "upscaleBy": {
      "type": "number",
      "default": 1.5,
      "description": "Upscale factor for hires fix",
      "nodeId": "10",
      "field": "inputs.scale_by"
    }
  },
  "prompt": {
    "1": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "{{checkpoint}}"
      },
      "_meta": { "title": "Load Checkpoint" }
    },
    "3": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{positivePrompt}}",
        "clip": ["1", 1]
      },
      "_meta": { "title": "Positive Prompt" }
    },
    "4": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{negativePrompt}}",
        "clip": ["1", 1]
      },
      "_meta": { "title": "Negative Prompt" }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": "{{width}}",
        "height": "{{height}}",
        "batch_size": "{{batchSize}}"
      },
      "_meta": { "title": "Empty Latent" }
    },
    "6": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["1", 0],
        "positive": ["3", 0],
        "negative": ["4", 0],
        "latent_image": ["5", 0],
        "seed": "{{seed}}",
        "steps": "{{steps}}",
        "cfg": "{{cfg}}",
        "sampler_name": "euler_ancestral",
        "scheduler": "normal",
        "denoise": 1.0
      },
      "_meta": { "title": "KSampler (Pass 1)" }
    },
    "7": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["6", 0],
        "vae": ["1", 2]
      },
      "_meta": { "title": "VAE Decode (Pass 1)" }
    },
    "10": {
      "class_type": "LatentUpscaleBy",
      "inputs": {
        "samples": ["6", 0],
        "upscale_method": "nearest-exact",
        "scale_by": "{{upscaleBy}}"
      },
      "_meta": { "title": "Latent Upscale" }
    },
    "9": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["1", 0],
        "positive": ["3", 0],
        "negative": ["4", 0],
        "latent_image": ["10", 0],
        "seed": "{{seed}}",
        "steps": "{{hiresSteps}}",
        "cfg": "{{cfg}}",
        "sampler_name": "euler_ancestral",
        "scheduler": "normal",
        "denoise": "{{hiresDenoise}}"
      },
      "_meta": { "title": "KSampler (HiRes Fix)" }
    },
    "11": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["9", 0],
        "vae": ["1", 2]
      },
      "_meta": { "title": "VAE Decode (HiRes)" }
    },
    "8": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["11", 0],
        "filename_prefix": "comfyui-remote"
      },
      "_meta": { "title": "Save Image" }
    }
  }
}
