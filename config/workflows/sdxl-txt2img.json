{
  "id": "sdxl-txt2img",
  "name": "SDXL Text-to-Image",
  "description": "Basic SDXL txt2img workflow with optional LoRA support. This is the built-in fallback workflow.",
  "version": "1.0.0",
  "builtIn": true,
  "variables": {
    "checkpoint": {
      "type": "string",
      "default": "sd_xl_base_1.0.safetensors",
      "description": "SDXL checkpoint file name",
      "nodeId": "1",
      "field": "inputs.ckpt_name"
    },
    "positivePrompt": {
      "type": "string",
      "default": "",
      "description": "Positive prompt text (composed from character + scene + style + position prompts)",
      "nodeId": "3",
      "field": "inputs.text"
    },
    "negativePrompt": {
      "type": "string",
      "default": "bad anatomy, extra limbs, blurry, low quality, watermark",
      "description": "Negative prompt text",
      "nodeId": "4",
      "field": "inputs.text"
    },
    "width": {
      "type": "number",
      "default": 896,
      "description": "Image width in pixels",
      "nodeId": "5",
      "field": "inputs.width"
    },
    "height": {
      "type": "number",
      "default": 1152,
      "description": "Image height in pixels",
      "nodeId": "5",
      "field": "inputs.height"
    },
    "batchSize": {
      "type": "number",
      "default": 1,
      "description": "Number of images to generate per run",
      "nodeId": "5",
      "field": "inputs.batch_size"
    },
    "seed": {
      "type": "number",
      "default": -1,
      "description": "Random seed (-1 for random)",
      "nodeId": "6",
      "field": "inputs.seed"
    },
    "steps": {
      "type": "number",
      "default": 25,
      "description": "Number of sampling steps",
      "nodeId": "6",
      "field": "inputs.steps"
    },
    "cfg": {
      "type": "number",
      "default": 7.0,
      "description": "Classifier-free guidance scale",
      "nodeId": "6",
      "field": "inputs.cfg"
    },
    "samplerName": {
      "type": "string",
      "default": "euler_ancestral",
      "description": "Sampler algorithm name",
      "nodeId": "6",
      "field": "inputs.sampler_name"
    },
    "scheduler": {
      "type": "string",
      "default": "normal",
      "description": "Scheduler algorithm name",
      "nodeId": "6",
      "field": "inputs.scheduler"
    }
  },
  "prompt": {
    "1": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "{{checkpoint}}"
      },
      "_meta": { "title": "Load Checkpoint" }
    },
    "3": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{positivePrompt}}",
        "clip": ["1", 1]
      },
      "_meta": { "title": "Positive Prompt" }
    },
    "4": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{negativePrompt}}",
        "clip": ["1", 1]
      },
      "_meta": { "title": "Negative Prompt" }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": "{{width}}",
        "height": "{{height}}",
        "batch_size": "{{batchSize}}"
      },
      "_meta": { "title": "Empty Latent" }
    },
    "6": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["1", 0],
        "positive": ["3", 0],
        "negative": ["4", 0],
        "latent_image": ["5", 0],
        "seed": "{{seed}}",
        "steps": "{{steps}}",
        "cfg": "{{cfg}}",
        "sampler_name": "{{samplerName}}",
        "scheduler": "{{scheduler}}",
        "denoise": 1.0
      },
      "_meta": { "title": "KSampler" }
    },
    "7": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["6", 0],
        "vae": ["1", 2]
      },
      "_meta": { "title": "VAE Decode" }
    },
    "8": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["7", 0],
        "filename_prefix": "comfyui-remote"
      },
      "_meta": { "title": "Save Image" }
    }
  }
}
