generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-sqlite"
}

datasource db {
  provider = "sqlite"
}

// Note: SQLite does not enforce enum values at the database level.
// Prisma handles validation at the application layer.

// ── Preset system ──

model PresetCategory {
  id                  String          @id @default(cuid())
  name                String          // e.g. "角色", "场景", "风格", "镜位"
  slug                String          @unique
  icon                String?         // lucide icon name for UI badge
  color               String?         // HSL color string
  positivePromptOrder Int             @default(0)
  negativePromptOrder Int             @default(0)
  lora1Order          Int             @default(0)
  lora2Order          Int             @default(0)
  sortOrder           Int             @default(0)
  type                String          @default("preset") // "preset" | "group"
  slotTemplate        Json?           // type=group: [{ categoryId: string, label?: string }]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  presets             Preset[]
  groups              PresetGroup[]
  folders             PresetFolder[]
}

model Preset {
  id              String          @id @default(cuid())
  categoryId      String
  name            String
  slug            String
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  notes           String?
  folderId        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  category        PresetCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  folder          PresetFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  variants        PresetVariant[]

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
}

model PresetVariant {
  id              String          @id @default(cuid())
  presetId        String
  name            String
  slug            String
  prompt          String          // positive prompt
  negativePrompt  String?
  lora1           Json?           // Array<LoraBinding> — stage 1
  lora2           Json?           // Array<LoraBinding> — stage 2 (upscale)
  defaultParams   Json?           // generation param defaults (aspect, batch, ksampler, etc.)
  linkedVariants  Json?           // [{ presetId: string, variantId: string }] — linked variant refs
  sortOrder       Int             @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  preset          Preset          @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@unique([presetId, slug])
  @@index([presetId, sortOrder])
}

model PresetGroup {
  id          String               @id @default(cuid())
  categoryId  String
  name        String
  slug        String
  sortOrder   Int                  @default(0)
  isActive    Boolean              @default(true)
  folderId    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  category    PresetCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  folder      PresetFolder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
  members     PresetGroupMember[]

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
}

model PresetGroupMember {
  id              String      @id @default(cuid())
  groupId         String
  presetId        String?     // reference a preset (+ optional variantId)
  variantId       String?     // specific variant of the preset
  subGroupId      String?     // or reference another group (mutually exclusive with presetId)
  slotCategoryId  String?     // if from slot template, locks to this category
  sortOrder       Int         @default(0)
  group           PresetGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, sortOrder])
}

model PresetFolder {
  id          String         @id @default(cuid())
  categoryId  String
  parentId    String?
  name        String
  sortOrder   Int            @default(0)
  category    PresetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  parent      PresetFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    PresetFolder[] @relation("FolderTree")
  presets     Preset[]
  groups      PresetGroup[]

  @@index([categoryId, parentId, sortOrder])
}

// ── Project Templates ──

model ProjectTemplate {
  id          String                  @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  sections    ProjectTemplateSection[]

  @@index([createdAt])
}

model ProjectTemplateSection {
  id                String            @id @default(cuid())
  projectTemplateId String
  sortOrder         Int               @default(0)
  name              String?
  aspectRatio       String?
  shortSidePx       Int?
  batchSize         Int?
  seedPolicy1       String?
  seedPolicy2       String?
  ksampler1         Json?
  ksampler2         Json?
  upscaleFactor     Float?
  loraConfig        Json?
  extraParams       Json?
  promptBlocks      Json?
  projectTemplate    ProjectTemplate  @relation(fields: [projectTemplateId], references: [id], onDelete: Cascade)

  @@index([projectTemplateId, sortOrder])
}

// ── Core models ──

model Project {
  id                    String                @id @default(cuid())
  title                 String
  slug                  String                @unique
  status                String                @default("draft")
  presetBindings        Json?                 // [{ categoryId, presetId, variantId? }]
  projectLevelOverrides Json?
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  sections              ProjectSection[]
  runs                  Run[]
  revisions             ProjectRevision[]

  @@index([status, updatedAt])
}

model ProjectSection {
  id                    String                @id @default(cuid())
  projectId             String
  name                  String?
  sortOrder             Int                   @default(0)
  enabled               Boolean               @default(true)
  positivePrompt        String?
  negativePrompt        String?
  aspectRatio           String?
  shortSidePx           Int?
  batchSize             Int?
  seedPolicy1           String?
  seedPolicy2           String?
  ksampler1             Json?
  ksampler2             Json?
  upscaleFactor         Float?
  loraConfig            Json?                 // { lora1: LoraEntry[], lora2: LoraEntry[] }
  extraParams           Json?
  latestRunId           String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs                  Run[]
  promptBlocks          PromptBlock[]

  @@index([projectId, sortOrder])
}

model PromptBlock {
  id                    String                @id @default(cuid())
  projectSectionId      String
  type                  String                @default("custom")
  sourceId              String?               // FK to Preset (when type="preset")
  variantId             String?               // FK to PresetVariant (current variant)
  categoryId            String?               // FK to PresetCategory
  bindingId             String?               // groups blocks+loras from same preset import
  groupBindingId        String?               // groups all bindings from same group import
  label                 String
  positive              String
  negative              String?
  sortOrder             Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  projectSection        ProjectSection        @relation(fields: [projectSectionId], references: [id], onDelete: Cascade)

  @@index([projectSectionId, sortOrder])
}

model Run {
  id                    String                @id @default(cuid())
  projectId             String
  projectSectionId      String
  runIndex              Int                   @default(1)
  status                String                @default("queued")
  resolvedConfigSnapshot Json
  comfyPromptId         String?
  executionMeta         Json?
  submittedPrompt       Json?               // Full submitted ComfyUI workflow JSON
  outputDir             String?
  errorMessage          String?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectSection        ProjectSection        @relation(fields: [projectSectionId], references: [id], onDelete: Cascade)
  images                ImageResult[]

  @@index([status, createdAt])
  @@index([projectId, createdAt])
  @@index([projectSectionId, createdAt])
}

model ImageResult {
  id                    String          @id @default(cuid())
  runId                 String
  filePath              String          @unique
  thumbPath             String?
  width                 Int?
  height                Int?
  fileSize              BigInt?
  reviewStatus          String          @default("pending")
  featured              Boolean         @default(false)
  reviewedAt            DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  run                   Run             @relation(fields: [runId], references: [id], onDelete: Cascade)
  trashRecord           TrashRecord?

  @@index([reviewStatus, createdAt])
  @@index([runId, createdAt])
}

model TrashRecord {
  id                    String       @id @default(cuid())
  imageResultId         String       @unique
  originalPath          String
  trashPath             String
  reason                String?
  deletedAt             DateTime     @default(now())
  restoredAt            DateTime?
  actorType             String       @default("user")
  imageResult           ImageResult  @relation(fields: [imageResultId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@index([restoredAt])
}

model LoraAsset {
  id                    String      @id @default(cuid())
  name                  String
  category              String
  fileName              String
  absolutePath          String      @unique
  relativePath          String
  size                  BigInt?
  source                String?
  notes                 String?
  triggerWords          String?     // trigger words for this LoRA
  uploadedAt            DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model ProjectRevision {
  id                    String      @id @default(cuid())
  projectId             String
  revisionNumber        Int
  snapshot              Json
  createdAt             DateTime    @default(now())
  actorType             String      @default("user")
  project               Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, revisionNumber])
  @@index([projectId, createdAt])
}

model AuditLog {
  id                    String      @id @default(cuid())
  entityType            String
  entityId              String
  action                String
  payload               Json?
  actorType             String      @default("system")
  createdAt             DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}
