generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-sqlite"
}

datasource db {
  provider = "sqlite"
}

// Note: SQLite does not enforce enum values at the database level.
// Prisma handles validation at the application layer.

// ── Unified prompt system ──

model PromptCategory {
  id                  String          @id @default(cuid())
  name                String          // e.g. "角色", "场景", "风格", "镜位"
  slug                String          @unique
  icon                String?         // lucide icon name for UI badge
  color               String?         // tailwind color key: "sky", "emerald", "violet", "amber"
  positivePromptOrder Int             @default(0)
  negativePromptOrder Int             @default(0)
  lora1Order          Int             @default(0)
  lora2Order          Int             @default(0)
  sortOrder           Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  presets             PromptPreset[]
}

model PromptPreset {
  id              String          @id @default(cuid())
  categoryId      String
  name            String
  slug            String          @unique
  prompt          String          // positive prompt
  negativePrompt  String?
  lora1           Json?           // Array<LoraBinding> — stage 1
  lora2           Json?           // Array<LoraBinding> — stage 2 (upscale)
  defaultParams   Json?           // generation param defaults (aspect, batch, ksampler, etc.)
  notes           String?
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  category        PromptCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId, sortOrder])
}

// ── Core models ──

model Project {
  id                    String                @id @default(cuid())
  title                 String
  slug                  String                @unique
  status                String                @default("draft")
  presetBindings        Json?                 // [{ categoryId, presetId }]
  projectLevelOverrides Json?
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  sections              ProjectSection[]
  runs                  PositionRun[]
  revisions             ProjectRevision[]

  @@index([status, updatedAt])
}

model ProjectSection {
  id                    String                @id @default(cuid())
  projectId             String
  name                  String?
  sortOrder             Int                   @default(0)
  enabled               Boolean               @default(true)
  positivePrompt        String?
  negativePrompt        String?
  aspectRatio           String?
  shortSidePx           Int?
  batchSize             Int?
  seedPolicy1           String?
  seedPolicy2           String?
  ksampler1             Json?
  ksampler2             Json?
  upscaleFactor         Float?
  loraConfig            Json?                 // { lora1: LoraEntry[], lora2: LoraEntry[] }
  extraParams           Json?
  latestRunId           String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs                  PositionRun[]
  promptBlocks          PromptBlock[]

  @@index([projectId, sortOrder])
}

model PromptBlock {
  id                    String                @id @default(cuid())
  projectSectionId      String
  type                  String                @default("custom")
  sourceId              String?
  categoryId            String?               // FK to PromptCategory
  label                 String
  positive              String
  negative              String?
  sortOrder             Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  projectSection        ProjectSection        @relation(fields: [projectSectionId], references: [id], onDelete: Cascade)

  @@index([projectSectionId, sortOrder])
}

model PositionRun {
  id                    String                @id @default(cuid())
  projectId             String
  projectSectionId      String
  runIndex              Int                   @default(1)
  status                String                @default("queued")
  resolvedConfigSnapshot Json
  comfyPromptId         String?
  outputDir             String?
  errorMessage          String?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectSection        ProjectSection        @relation(fields: [projectSectionId], references: [id], onDelete: Cascade)
  images                ImageResult[]

  @@index([status, createdAt])
  @@index([projectId, createdAt])
  @@index([projectSectionId, createdAt])
}

model ImageResult {
  id                    String          @id @default(cuid())
  positionRunId         String
  filePath              String          @unique
  thumbPath             String?
  width                 Int?
  height                Int?
  fileSize              BigInt?
  reviewStatus          String          @default("pending")
  featured              Boolean         @default(false)
  reviewedAt            DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  positionRun           PositionRun     @relation(fields: [positionRunId], references: [id], onDelete: Cascade)
  trashRecord           TrashRecord?

  @@index([reviewStatus, createdAt])
  @@index([positionRunId, createdAt])
}

model TrashRecord {
  id                    String       @id @default(cuid())
  imageResultId         String       @unique
  originalPath          String
  trashPath             String
  reason                String?
  deletedAt             DateTime     @default(now())
  restoredAt            DateTime?
  actorType             String       @default("user")
  imageResult           ImageResult  @relation(fields: [imageResultId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@index([restoredAt])
}

model LoraAsset {
  id                    String      @id @default(cuid())
  name                  String
  category              String
  fileName              String
  absolutePath          String      @unique
  relativePath          String
  size                  BigInt?
  source                String?
  notes                 String?
  uploadedAt            DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model ProjectRevision {
  id                    String      @id @default(cuid())
  projectId             String
  revisionNumber        Int
  snapshot              Json
  createdAt             DateTime    @default(now())
  actorType             String      @default("user")
  project               Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, revisionNumber])
  @@index([projectId, createdAt])
}

model AuditLog {
  id                    String      @id @default(cuid())
  entityType            String
  entityId              String
  action                String
  payload               Json?
  actorType             String      @default("system")
  createdAt             DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}
